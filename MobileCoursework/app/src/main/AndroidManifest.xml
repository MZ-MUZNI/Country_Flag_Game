<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MobileCoursework"
        tools:targetApi="31">
        <activity
            android:name=".AdvanceLevel"
            android:exported="false"
            android:label="@string/title_activity_advance_level"
            android:theme="@style/Theme.MobileCoursework" />
        <activity
            android:name=".AdvancedLevel"
            android:exported="false"
            android:label="@string/title_activity_advanced_level"
            android:theme="@style/Theme.MobileCoursework" />
        <activity
            android:name=".GuessTheFlag"
            android:exported="false"
            android:label="@string/title_activity_guessthe_flag"
            android:theme="@style/Theme.MobileCoursework" />
        <activity
            android:name=".GuessHints"
            android:exported="false"
            android:label="@string/title_activity_guess_hints"
            android:theme="@style/Theme.MobileCoursework" />
        <activity
            android:name=".GuessTheCountry"
            android:exported="false"
            android:label="@string/title_activity_guessthe_country"
            android:theme="@style/Theme.MobileCoursework" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MobileCoursework">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>